<style>

    /* Glassmorphism container */
    .glass-container {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 20px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
        border: 1px solid rgba(255, 255, 255, 0.18);
        padding: 2.5rem;
        width: 100%;
        color: white;
    }

    /* Glassmorphism form elements */
    .glass-input {
        background: white;
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 10px;
        color: gray;
        padding: 12px 15px;
        transition: all 0.3s ease;
    }

    .glass-input:focus {
        background:white;
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: 0 0 0 0.2rem rgba(255, 255, 255, 0.25);
        color: gray;
    }

    .glass-input::placeholder {
        color: gray;
    }

    .glass-select {
        background:white;
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 10px;
        color: gray;
        padding: 12px 15px;
    }

    .glass-select option {
        background:white;
        color: gray;
    }

    .glass-button {
    background-color: #660034;
    border: 1px solid #660034;
    border-radius: 10px;
    color: white;
    padding: 12px;
    font-weight: 600;
    transition: all 0.4s ease-in-out;
    animation: pulse 4s infinite alternate ease-in-out; /* hamesha slow pulse */
}

    .glass-button:hover {
        color: white;
        background-color:  rgba(121, 22, 73, 0.8);
        transform: translateY(-3px) scale(1.02); /* halki si upar aur zoom */
        box-shadow: 0 0 20px rgba(78, 0, 40, 0.8);
    }

    @keyframes  pulse {
        0% {
            box-shadow: 0 0 5px rgba(78, 0, 40, 0.3);
        }
        100% {
            box-shadow: 0 0 15px rgba(78, 0, 40, 0.7);
        }
    }


    .glass-link {
        color: #660034;
        text-decoration: none;
        font-size: 1.2rem;
        transition: color 0.3s ease;
    }

    .glass-link:hover {
        color: white;
        text-decoration: underline;
    }

    /* Header styling */
    .glass-header {
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        padding-bottom: 1rem;
        margin-bottom: 1.5rem;
    }

    /* Divider styling */
    .glass-divider {
        border-top: 1px solid rgba(255, 255, 255, 0.2);
        position: relative;
        margin: 1.5rem 0;
    }

    .glass-divider-text {
        background: rgba(255, 255, 255, 0.15);
        padding: 0 10px;
        position: absolute;
        top: -10px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 0.9rem;
    }

    /* Error message styling */
    .error-message {
        background: rgba(220, 53, 69, 0.3);
        border: 1px solid rgba(220, 53, 69, 0.5);
        border-radius: 5px;
        padding: 10px;
        margin-top: 10px;
        font-size: 0.9rem;
    }

     @media (min-width: 370px) and (max-width: 540px) {

        .glass-container {
            width: 90% !important;
        }

       }

    /* Responsive adjustments */
    @media (max-width: 576px) {
        .glass-container {
            width: 90% !important;
        }

    }



