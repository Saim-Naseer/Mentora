<script>
    $(":input").inputmask();
    $(document).ready(function() {
        var options = $('#cnic_pass').val();
        if (options == "CNIC") {
            $('#cnic').removeClass("d-none");
            $('#passport').addClass("d-none");
        } else {
            $('#cnic').addClass("d-none");
            $('#passport').removeClass("d-none");
        }
        $('#cnic_pass').change(function(event) {
            options = $('#cnic_pass').val();
            if (options == "CNIC") {
                $('#cnic').removeClass("d-none");
                $('#passport').addClass("d-none");
            } else {
                $('#cnic').addClass("d-none");
                $('#passport').removeClass("d-none");
            }
        });
    });
</script>

