	<script type="text/javascript">
		$(document).ready(function(){
			$('#loginTitle').html('Login With Online Admission Credentials');
					$('#labelTitle').html('CNIC/Passport');
					$('#description').html('<small style="color:red">Please Enter CNIC#. with dashes (-)</small>');
					$('#user_name').removeClass('validate[required,custom[integer],maxSize[5]]');
					$('#user_name').addClass('validate[required]');
					$("#user_name").attr("placeholder", "XXXXX-XXXXXXX-X")
			$(document).on('change','#login_as',function(){
				var login_as = $(this).val();
				if(login_as == "1"){
					$('#loginTitle').html('Login With Wifi Credentials');
					$('#labelTitle').html('ERP ID');
					$('#description').html('');
					$('#user_name').removeClass('validate[required]');
					$('#user_name').addClass('validate[required,custom[integer],maxSize[5]]');
					$("#user_name").attr("placeholder", "xxxxx")
				} else if(login_as == "0"){
					$('#loginTitle').html('Login With Online Admission Credentials');
					$('#labelTitle').html('CNIC/Passport');
					$('#description').html('<small style="color:red">Please Enter CNIC#. with dashes (-)</small>');
					$('#user_name').removeClass('validate[required,custom[integer],maxSize[5]]');
					$('#user_name').addClass('validate[required]');
					$("#user_name").attr("placeholder", "XXXXX-XXXXXXX-X")
				}  else if(login_as == "2"){
					$('#loginTitle').html('Login With CNIC and Password sent on your Email');
					$('#labelTitle').html('CNIC');
					$('#description').html('<small style="color:red">Please Enter CNIC# without dashes (-)</small>');
					$('#user_name').removeClass('validate[required,custom[integer],maxSize[5]]');
					$('#user_name').addClass('validate[required,custom[integer],maxSize[13]]');
					$("#user_name").attr("placeholder", "XXXXXXXXXXXXX")
				}
			});
		});
	</script>
