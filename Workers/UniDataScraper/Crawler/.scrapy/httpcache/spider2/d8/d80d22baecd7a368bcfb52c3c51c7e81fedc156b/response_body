	<div class="limiter">
		<div class="container-login100">
			<div class="heading" style="padding:5px;">
			<h2 data-toggle="tooltip" data-placement="top" title="Login" id="loginTitle">Login with Online Admission Credentials</h2>
			<!-- <h2 data-toggle="tooltip" data-placement="top" title="Login" id="loginTitle">Login With Wifi Credentials</h2> -->
			</div>
			<div class="wrap-login100 p-l-55 p-r-55 p-t-65 p-b-50">
		        			  	<form class="login100-form validate-form" id="login_form" method="post" action="https://ibaapps.iba.edu.pk/financialassistance/home/checklogin">
					<label for="country" class="test">Login as</label>
					<div class="wrap-input100 validate-input" data-validate="Valid email is required">
						<select name="login_type"  class="input100 form-control validate[required]" id="login_as">
			            <option value="">Select Login Type</option>
			            			        	 <option  value="0">Fresh Student</option>
			        	 <!-- <option value="2">NTHP Orientation students of Batch 2026</option> -->
			      		<option value="1">Existing Student</option>
		              </select>
					</div>
                    <label for="country" class="test" id="labelTitle">ERP ID </label>
					<div class="wrap-input100 validate-input" data-validate="Valid email is required">
						<input class="input100 form-control " type="text" name="user_name" placeholder="User Name" id="user_name">
						<span id="description"></span>
					</div>
					<label for="country" class="test">Password </label>
					<div class="wrap-input100 rs1 validate-input" data-validate="Password is required">
						<input class="input100 form-control validate[required]" type="password" name="password" placeholder="Password">
					</div>
   					<div class="container-login100-form-btn m-t-20">
                        <input class="submit login100-form-btn" type="submit" value="Login"/>
					</div>

					<p style="padding-top:50px;color:black">
						<hr>Note: 
						<br>
						<b>1. Fresh Students</b>: 
							<br>
							&nbsp;&nbsp;&nbsp;&nbsp;&diams;
							Please Enter CNIC No. with dashes (-)
							<br> 
							&nbsp;&nbsp;&nbsp;&nbsp;&diams;
							Login with your <a href="https://onlineadmission.iba.edu.pk/" target="_blank">online admission</a> credentials. 
							<br>
							&nbsp;&nbsp;&nbsp;&nbsp;&diams;
							If you forgot your password kindly reset your password <a href="https://onlineadmission.iba.edu.pk/admissions/otp" target="_blank">here</a>. 
						<br><hr>
						<!-- <b>2. Existing Students</b>: If you forgot your password please email <b>ERP_Helpdesk@iba.edu.pk</b> to reset your credentials.  -->
						<b>2. Existing Students</b>: 
							<br> &nbsp;&nbsp;&nbsp;&nbsp;&diams; <span class="text-danger">Please use Wi-fi credentials</span>
							<br> &nbsp;&nbsp;&nbsp;&nbsp;&diams; If you forgot your password please email <b>mkahmed@iba.edu.pk | anaqvi@iba.edu.pk</b> to reset your credentials. 
						<br><hr>
						<b>3.</b> If you are facing any difficulty regarding form submission, drop an email at <b>aasoomro@iba.edu.pk </b>for technical assistance.
						<!-- <b>2. Existing Students</b>: If you forgot your password please email <b>ERP_Helpdesk@iba.edu.pk</b> to reset your credentials.  -->
												<b>3.</b> If you are facing any difficulty regarding form submission, drop an email at <b><br>financial-aid@iba.edu.pk </b>for assistance.
					</p>
				</form>
			</div>
		</div>
	</div>
