<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>New Admission Portal - Coming Soon - BZU</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      height: 100vh;
      background: radial-gradient(circle at center, #1f1f47, #0f0f2d);
      color: #f1f1f1;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      margin: 0;
    }
    .coming-soon-box {
      background: rgba(255, 255, 255, 0.05);
      padding: 50px 40px;
      border-radius: 16px;
      text-align: center;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(8px);
      animation: fadeIn 1.2s ease-in-out;
    }
    h1 {
      font-size: 3.2rem;
      margin-bottom: 20px;
      font-weight: bold;
    }
    p {
      font-size: 1.25rem;
      margin-bottom: 30px;
    }
    .footer {
      font-size: 0.95rem;
      color: #cccccc;
    }
    .footer a {
      color: #ffffff;
      text-decoration: underline;
    }
    @keyframes fadeIn {
      0% { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>

  <div class="container">
    <div class="row justify-content-center align-items-center">
      <div class="col-md-10 col-lg-6">
        <div class="coming-soon-box">
          <h1>🚧 Coming Soon</h1>
          <p><strong>BZU's New Admission Portal</strong> will be live very soon. Stay connected for updates!</p>
          <hr class="border-secondary my-4">
          <p class="footer">
            © 2025 Bahauddin Zakariya University, Multan<br>
            <a href="https://www.bzu.edu.pk" target="_blank">www.bzu.edu.pk</a>
          </p>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
