                        alert("Kindly Checked Privacy Policy.");
                    }
                    else {
                        $.ajax({
                            type: "POST",
                            url: "/CoEE/Login/SaveApplicatDataForEnrollment",
                            data: $("#RegisterForm").serialize(),
                            beforeSend: function () {

                            },
                            success: function (response) {
                                debugger;
                                if (response.success) {
                                    $('#RegisterForm').find("div").removeClass('has-error');
                                    $('.field-validation-valid').empty();
                                    $('.field-validation-error').empty();
                                    window.location.href = '/CoEE/Applicant';
                                    /* window.location = "/Applicant/Index";*/
                                } else {
                                    // Clear existing error messages
                                    $('#RegisterForm').find("div").removeClass('has-error');
                                    $('.field-validation-valid').empty();
                                    $('.field-validation-error').empty();
                                    // Display error messages using ValidationMessageFor
                                    $.each(response.errors, function (index, error) {
                                        var fieldName = error.FieldName;
                                        var errorMessage = error.ErrorMessage;
                                        var validationMessage = $('<span />').addClass('field-validation-error').text(errorMessage);
                                        $('[name="' + fieldName + '"]').closest('div.form-group').addClass('has-error');
                                        $('[name="' + fieldName + '"]').closest('div.form-group').find(".field-validation-valid").after(validationMessage);
                                    });

                                    //$(".RegisterFormAlert").html(response.ExceptionMessage);
                                    //$(".RegisterFormAlertDiv").show();
                                }
                            },
                            error: function (result) {
                                $(".RegisterFormAlert").html("ERROR! Please try again");
                                $(".RegisterFormAlertDiv").show();
                            }
                        });
                    }

                });
            

