    <script>

        $("body").on("mousedown", ".bx-viewport a", function () {
            if ($(this).attr("href") && $(this).attr("href") != "#") {
                window.location = $(this).attr("href");
            }
        });


        $('.bxslider').bxSlider({
            auto: true,
            autoControls: true,
            stopAutoOnClick: true,
            pager: true,
            /*slideWidth: 1920,*/
            responsive: true,
            adaptiveHeight: true,
            slideWidth: 0,
            speed: 1000,
            pause: 6000,
        });

        function adjustSliderForMobile() {
            const slider = document.getElementById('bxslider');
            if (window.innerWidth <= 578) {
                const translateX = -window.innerWidth * 0.98; // Adjust the multiplier as needed
                slider.style.transform = `translate3d(${translateX}px, 0px, 0px)`;
            } else {
                slider.style.transform = ''; // Resets for larger screens
            }
        }

        // Run the function initially and on resize
        window.addEventListener('resize', adjustSliderForMobile);
        adjustSliderForMobile();

    </script>
