    <script>

        function applyHoverEffect(circleid, ovalid, detailsDivId, imageName) {
            var div1 = document.getElementById(circleid);
            var div2 = document.getElementById(ovalid);
            var divDetails = document.getElementById(detailsDivId);
            var imgMap = document.getElementById('imgMap');

            HideDetailsDiv(1);

            div1.classList.add("hover1");
            div2.classList.add("hover1");
            divDetails.style.visibility = 'visible';
            divDetails.style.height = '';

            imgMap.src = '/img/vucamp/' + imageName;

        }

        function removeHoverEffect() {
            var div1 = document.getElementById("divCircleIsb");
            var div2 = document.getElementById("divOvalIsb");
            var div3 = document.getElementById("divCirclePunjab");
            var div4 = document.getElementById("divOvalPunjab");
            var div5 = document.getElementById("divCircleSindh");
            var div6 = document.getElementById("divOvalSindh");
            var div7 = document.getElementById("divCircleBlochistan");
            var div8 = document.getElementById("divOvalBlochistan");
            var div9 = document.getElementById("divCircleKyberPakhunkhwa");
            var div10 = document.getElementById("divOvalKyberPakhunkhwa");
            var div11 = document.getElementById("divCircleAzadKashmir");
            var div12 = document.getElementById("divOvalAzadKashmir");
            var div13 = document.getElementById("divCircleGilgitBaltistan");
            var div14 = document.getElementById("divOvalGilgitBaltistan");
            var div15 = document.getElementById("divCircleoverseas");
            var div16 = document.getElementById("divOvaloverseas");
            var div17 = document.getElementById("divCirclePakistan");
            var div18 = document.getElementById("divOvalPakistan");


            var imgMap = document.getElementById('imgMap');
            imgMap.src = '/img/vucamp/map.png'


            div1.classList.remove("hover1");
            div2.classList.remove("hover1");
            div3.classList.remove("hover1");
            div4.classList.remove("hover1");
            div5.classList.remove("hover1");
            div6.classList.remove("hover1");
            div7.classList.remove("hover1");
            div8.classList.remove("hover1");
            div9.classList.remove("hover1");
            div10.classList.remove("hover1");
            div11.classList.remove("hover1");
            div12.classList.remove("hover1");
            div13.classList.remove("hover1");
            div14.classList.remove("hover1");
            div15.classList.remove("hover1");
            div16.classList.remove("hover1");
            div17.classList.remove("hover1");
            div18.classList.remove("hover1");

            HideDetailsDiv(0);

        }

        function HideDetailsDiv(hidePakistan) {

            var divDetails1 = document.getElementById("divIsbDetails");
            var divDetails2 = document.getElementById("divPunjabDetails");
            var divDetails3 = document.getElementById("divSindhDetails");
            var divDetails4 = document.getElementById("divBlochistanDetails");
            var divDetails5 = document.getElementById("divKPKDetails");
            var divDetails6 = document.getElementById("divAJKDetails");
            var divDetails7 = document.getElementById("divGBDetails");
            var divDetails8 = document.getElementById("divOverseasDetails");
            var divDetails9 = document.getElementById("divPakistanDetails");

            divDetails1.style.visibility = 'hidden';
            divDetails2.style.visibility = 'hidden';
            divDetails3.style.visibility = 'hidden';
            divDetails4.style.visibility = 'hidden';
            divDetails5.style.visibility = 'hidden';
            divDetails6.style.visibility = 'hidden';
            divDetails7.style.visibility = 'hidden';
            divDetails8.style.visibility = 'hidden';

            if (hidePakistan == 1) {
                divDetails9.style.visibility = 'hidden';
                divDetails9.style.height = '0px';
            }
            else {
                divDetails9.style.visibility = 'visible';
                divDetails9.style.height = '';
            }


            divDetails1.style.height = '0px';
            divDetails2.style.height = '0px';
            divDetails3.style.height = '0px';
            divDetails4.style.height = '0px';
            divDetails5.style.height = '0px';
            divDetails6.style.height = '0px';
            divDetails7.style.height = '0px';
            divDetails8.style.height = '0px';

        }

    </script>


