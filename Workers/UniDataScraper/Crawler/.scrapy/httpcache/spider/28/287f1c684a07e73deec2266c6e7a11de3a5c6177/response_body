    #testimonial .proRector{background:#fff url(https://numl.edu.pk/templates/template10/images/pro_rector.png)}   

    #testimonial #bg{width:100%;height:100%;position:absolute}
    #testimonial .slide{width:100%;height:100%;position:absolute;opacity:0;-webkit-transition:all 1.5s ease;-moz-transition:all 1.5s ease;-o-transition:all 1.5s ease;transition:all 1.5s ease}
