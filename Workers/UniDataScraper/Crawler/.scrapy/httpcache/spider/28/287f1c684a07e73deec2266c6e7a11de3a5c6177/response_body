    #testimonial p.quote.active{right:0;opacity:1;background:transparent; width:100%; display:block;}
    #testimonial p.quote.active i {color: #FFFFFF;}
    #testimonial .active{/*background:#092A4B;*/ }
    #testimonial .readMoreBtn{ width:25%;}
