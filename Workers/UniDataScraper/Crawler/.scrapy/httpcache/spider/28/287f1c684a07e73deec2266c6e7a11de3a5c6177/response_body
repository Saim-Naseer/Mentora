    #testimonial #rightBtn{width:50%;height:100%;float:right;color:rgba(255,255,255,.57);background:#232323;font-size:25px;line-height:200%;text-align:center;border-left:1px solid rgba(255,255,255,.57);cursor:pointer;-webkit-transition:all .3s ease-in;-moz-transition:all .3s ease-in;-o-transition:all .3s ease-in;transition:all .3s ease-in}
    #testimonial #leftBtn:hover,#rightBtn:hover{color:#fff}
    #testimonial #nav-cirlces{width:96px;height:20px;position:absolute;bottom:8%;left:50%;margin-left:-50px}
