    function showhideOtherOffices() {


        var btnOtherOffices = document.getElementById("btnOtherOffices");


        if (btnOtherOffices.value == "Show Other Offices") {
            btnOtherOffices.value = "Hide Other Offices";
        }
        else {
            btnOtherOffices.value = "Show Other Offices";
        }

        var trLawrenceRoad = document.getElementById("trLawrenceRoad");
        var trIslamabadOffice = document.getElementById("trIslamabadOffice");
        var trKarachiOffice = document.getElementById("trKarachiOffice");
        var trRawalpindiOffice = document.getElementById("trRawalpindiOffice");

        if (trLawrenceRoad.style.display != "none") {
            trLawrenceRoad.style.display = "none";

        }
        else {
            trLawrenceRoad.style.display = "table-row";
        }


        if (trIslamabadOffice.style.display != "none") {
            trIslamabadOffice.style.display = "none";

        }
        else {
            trIslamabadOffice.style.display = "table-row";
        }

        if (trKarachiOffice.style.display != "none") {
            trKarachiOffice.style.display = "none";

        }
        else {
            trKarachiOffice.style.display = "table-row";
        }

        if (trRawalpindiOffice.style.display != "none") {
            trRawalpindiOffice.style.display = "none";

        }
        else {
            trRawalpindiOffice.style.display = "table-row";
        }

        return false;
    }


    function validateSearch() {
        var obj_search_box = document.getElementById('txtSearchContacts')

        if (obj_search_box.value == '')
            return false;
        else
            return true;
    }


    function showHideImage(header) {

        var obj_img = document.getElementById('img_' + header.id);
        var imageName = obj_img.src.substring(obj_img.src.lastIndexOf('/') + 1, obj_img.src.length - 4);

        var obj_email = document.getElementById('email_' + header.id);
        var obj_ext = document.getElementById('ext_' + header.id);



        if (imageName == 'icon_expand') {
            obj_email.style.visibility = "visible";
            obj_ext.style.visibility = "visible";


            obj_img.src = 'images/icon_collapse.png';
            obj_img.title = 'Click here to Hide all contacts';
        }
        else if (imageName == 'icon_collapse') {
            obj_email.style.visibility = "hidden";
            obj_ext.style.visibility = "hidden";


            obj_img.src = 'images/icon_expand.png';
            obj_img.title = 'Click here to Show all contacts';
        }

        else if (imageName == 'expand') {
            
            obj_img.src = 'images/treeview/collapse.gif';
            obj_img.title = 'Click here to Hide all contacts';
        }
        else {
            obj_img.src = 'images/treeview/expand.gif';
            obj_img.title = 'Click here to Show all contacts';
        }

        //alert(imageName);
        return true;
    }


</script>

