ment_for_enrolled_student": [],\n      "curriculum_notes": [],\n      "careers_info_notes": []\n    }\n  ],\n  "General Admission Steps": [\n    {\n      "val": "Visit: https://admissions.iqra.edu.pk, enter personal details and preferred campus. Admission Code & Applicant ID generated.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Complete Admission Form sections: Admission Info, Basic Info, Residence Info, Guardian’s Info, Academic Info, Documents, Agreement.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Processing fees: PKR 1000 (non‑refundable). Pay online or at campus and upload voucher.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Admit card issued automatically after requirements met; if not received, visit campus or email admission@iqra.edu.pk.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Entrance test date communicated via email & SMS; computer‑based MCQs covering English, Mathematics, General Knowledge & IQ.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Interview scheduled on test day or informed separately.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "After clearing test & interview, semester fee voucher issued (JS Bank or online). Upload paid voucher; upon confirmation Student ID issued.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    }\n  ],\n  "General Admission Notes": [\n    {\n      "val": "Admissions are announced through website and social media. Merit‑based selection requires passing admission test, interview, meeting program eligibility and submitting all credentials.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Admission timelines: Spring (March‑June) starts November, Summer (July‑September) starts April, Fall (October‑February) starts August.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Fee Refund Policy: Refunds only for new applicants against Tuition, LMS and Co‑Curricular charges. Up to 100% refund if request made within 10 days of class start, decreasing to 80% (15 days), 60% (20 days), 50% (30 days), none thereafter. Apply via email to admission@iqra.edu.pk with fee voucher attached.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "International student admission requires attested certificates, IBCC equivalence, passport, NOC from home country and HEC, medical fitness certificate, and English proficiency.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "International students can apply to scholarships limited to OIC member states, Sri Lanka and designated countries; contact <international.office@iqra.edu.pk>.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Student Exchange Programs (outbound & inbound) have detailed procedures, eligibility criteria, credit transfer policies and no tuition fee for inbound exchanges.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    }\n  ],\n  "Scholarship_notes": [\n    {\n      "val": "Merit Based Scholarship: Admission stage scholarships based on prior academics (45%+ marks) and admission test performance, ranging from 5% to 30% of 1st semester tuition fee, with a maximum ceiling of 35% for the 1st semester. Continuation scholarships based on CGPA (e.g., >3.75 CGPA = 60% tuition fee, >3.5 CGPA = 40%, >3.0 CGPA = 20%).",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Talent Based Scholarship: Awarded to students with gold/silver/bronze medals at regional/national/international events. 1st year only, 100% tuition fee for gold medalists, 90% for silver, 80% for bronze, with decreasing percentages for lower achievements.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Alumni Scholarship: Based on CGPA of previous degree – >3.75 CGPA = 30% tuition fee, 3.5‑3.75 = 25%, 3.0‑3.5 = 20%, 2.5‑3.0 = 15%. Continuation requires maintaining CGPA ≥2.5, no F grades, 80% attendance, and participation in IU Volunteer Program.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Loyalty (Sibling) Scholarship: 10% discount for one sibling, 15% for more than one sibling on tuition fee for both 1st and subsequent semesters, with conditions on CGPA and attendance.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Spouse & Children Scholarship: 20% tuition fee discount for spouse and children of IU graduates, subject to CGPA ≥2.5, attendance, and no disciplinary cases.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Faculty & Staff Scholarship: Tuition fee discounts based on years of service (e.g., >1 year = 25% for G1/G2 grades, up to 80% for >5 years for higher grades). Requires serving IU for at least one year after graduation.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Need Based Scholarship: Up to 100% tuition fee waiver based on financial assessment by Financial Assistance Committee. Eligibility requires meeting admission criteria, CGPA ≥2.5, no disciplinary cases, and 80% attendance.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Qarz‑E‑Hasana (interest‑free loan): Financial support up to 80% of tuition fee for deserving students, repayable within one year after graduation.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    },\n    {\n      "val": "Differently Abled Students Scholarship: 100% tuition fee waiver, 10‑year age relaxation, one seat for MS/M.Phil/PhD. Requires disability certificate and CGPA ≥2.5.",\n      "link": "https://iqra.edu.pk/admission-hub/",\n      "confidence": 1.0\n    }\n  ],\n  "research_and_faculty_notes": [],\n  "student_life": {\n    "clubs": [\n      {\n        "val": "Climate Change Society",\n        "link": "https://iqra.edu.pk/life-at-iu/",\n        "confidence": 0.9\n      },\n      {\n        "val": "Debates and Literary Society",\n        "link": "https://iqra.edu.pk/life-at-iu/",\n        "confidence": 0.9\n      },\n      {\n        "val": "Dramatics Society",\n        "link": "https://iqra.edu.pk/life-at-iu/",\n        "confidence": 0.9\n      },\n      {\n        "val": "Entrepreneurship Society",\n        "link": "https://iqra.edu.pk/life-at-iu/",\n        "confidence": 0.9\n      },\n      {\n        "val": "Events Society",\n        "link": "https://iqra.edu.pk/life-at-iu/",\n        "confidence": 0.9\n      },\n      {\n        "val": "Gaming & Robotics Society",\n        "link": "https://iqra.edu.pk/life-at-iu/",\n        "confidence": 0.9\n      },\n      {\n        "val": "IUCSR Society",\n        "link": "https://iqra.edu.pk/life-at-iu/",\n        "confidence": 0.9\n      },\n      {\n        "val": "Photography Society",\n        "link": "https://iqra.edu.pk/life-at-iu/",\n        "confidence": 0.9\n      },\n      {\n        "val": "Sports Society",\n        "link": "https://iqra.edu.pk/life-at-iu/",\n        "confidence": 0.9\n      },\n      {\n        "val": "Social Media Society",\n        "link": "https://iqra.edu.pk/life-at-iu/",\n        "confidence": 0.9\n      }\n    ],\n    "sports": [\n      {\n        "val": "Sauna Bath",\n     